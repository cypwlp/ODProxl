<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d"
             d:DesignWidth="960"
             d:DesignHeight="900"
             xmlns:vm="using:ODProxl.ViewModels.Pages"
             x:DataType="vm:UserPreferencePageViewModel"
             x:Class="ODProxl.UserPreferencePage">

    <DockPanel>

        <!-- 底部固定按鈕區域 -->
        <Border DockPanel.Dock="Bottom"
                Margin="32,20,32,32"
                Padding="0,16,0,0"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="16">
                <Button Content="取消"
                        Theme="{DynamicResource MaterialOutlinedButton}"
                        MinWidth="120" />
                <Button Content="儲存變更"
                        Theme="{DynamicResource MaterialFilledButton}"
                        Command="{Binding SaveCommandAsync}"
                        MinWidth="140" />
            </StackPanel>
        </Border>

        <!-- 可滾動的主要內容區域 -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Padding="32,24">

            <StackPanel Spacing="40" MaxWidth="920" HorizontalAlignment="Stretch">

                <!-- 頁面標題 -->
                <StackPanel Spacing="8">
                    <TextBlock Text="用戶偏好設定"
                               Classes="Headline4"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryBrush}" />
                    <TextBlock Text="自訂你的帳戶、外觀與應用程式行為"
                               Classes="Body1"
                               Opacity="0.75" />
                </StackPanel>

                <!-- 通用設定 -->
                <Border Classes="Card" Padding="28" CornerRadius="16" BoxShadow="0 4 16 0 #1F000000">
                    <StackPanel Spacing="24">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <avalonia:MaterialIcon Kind="AccountCircle"
                                                   Width="32" Height="32"
                                                   Foreground="{DynamicResource PrimaryBrush}" />
                            <StackPanel Spacing="4">
                                <TextBlock Text="通用" Classes="Headline6" />
                                <TextBlock Text="帳戶與基本偏好" Classes="Body2" Opacity="0.7" />
                            </StackPanel>
                        </StackPanel>
                        <Separator />
                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" Margin="4,0">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="使用者帳號"
                                       VerticalAlignment="Center" Classes="Body1" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentUserAccount}"
                                       Margin="32,0,0,0" VerticalAlignment="Center" Opacity="0.85" />
                            <Button Grid.Row="0" Grid.Column="2" Content="修改"
                                    Theme="{DynamicResource MaterialOutlinedButton}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="顯示名稱"
                                       Margin="0,20,0,0" VerticalAlignment="Center" Classes="Body1" />
                            <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                     Margin="32,20,0,0"
                                     Text="{Binding DisplayName}"
                                     Watermark="輸入顯示名稱" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 外觀設定 -->
                <Border Classes="Card" Padding="28" CornerRadius="16" BoxShadow="0 4 16 0 #1F000000">
                    <StackPanel Spacing="24">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <avalonia:MaterialIcon Kind="Palette"
                                                   Width="32" Height="32"
                                                   Foreground="{DynamicResource PrimaryBrush}" />
                            <StackPanel Spacing="4">
                                <TextBlock Text="外觀" Classes="Headline6" />
                                <TextBlock Text="主題、顏色與語言" Classes="Body2" Opacity="0.7" />
                            </StackPanel>
                        </StackPanel>
                        <Separator />
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" Margin="4,0">
                            <TextBlock Grid.Row="0" Text="應用程式主題" VerticalAlignment="Center" Classes="Body1" />
                            <ComboBox Grid.Row="0" Grid.Column="1" Width="200" SelectedIndex="0">
                                <ComboBoxItem>跟隨系統</ComboBoxItem>
                                <ComboBoxItem>淺色</ComboBoxItem>
                                <ComboBoxItem>深色</ComboBoxItem>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Text="語言" Margin="0,20,0,0" VerticalAlignment="Center" Classes="Body1" />
                            <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,20,0,0" Width="200">
                                <ComboBoxItem>繁體中文 (台灣)</ComboBoxItem>
                                <ComboBoxItem>繁體中文 (香港)</ComboBoxItem>
                                <ComboBoxItem>English</ComboBoxItem>
                                <ComboBoxItem>简体中文</ComboBoxItem>
                            </ComboBox>

                            <TextBlock Grid.Row="2" Text="啟用平滑動畫" Margin="0,20,0,0" VerticalAlignment="Center" Classes="Body1" />
                            <ToggleSwitch Grid.Row="2" Grid.Column="1" Margin="0,20,0,0" IsChecked="True" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 通知與提醒 -->
                <Border Classes="Card" Padding="28" CornerRadius="16" BoxShadow="0 4 16 0 #1F000000">
                    <StackPanel Spacing="24">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <avalonia:MaterialIcon Kind="Notifications"
                                                   Width="32" Height="32"
                                                   Foreground="{DynamicResource PrimaryBrush}" />
                            <StackPanel Spacing="4">
                                <TextBlock Text="通知" Classes="Headline6" />
                                <TextBlock Text="接收更新與提醒" Classes="Body2" Opacity="0.7" />
                            </StackPanel>
                        </StackPanel>
                        <Separator />
                        <StackPanel Spacing="12">
                            <CheckBox Content="啟用桌面通知" IsChecked="True" />
                            <CheckBox Content="接收系統更新通知" IsChecked="True" />
                            <CheckBox Content="顯示每日提示" IsChecked="False" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 進階設定 -->
                <Border Classes="Card" Padding="28" CornerRadius="16" BoxShadow="0 4 16 0 #1F000000">
                    <StackPanel Spacing="24">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <avalonia:MaterialIcon Kind="Settings"
                                                   Width="32" Height="32"
                                                   Foreground="{DynamicResource PrimaryBrush}" />
                            <StackPanel Spacing="4">
                                <TextBlock Text="進階" Classes="Headline6" />
                                <TextBlock Text="效能與資料管理" Classes="Body2" Opacity="0.7" />
                            </StackPanel>
                        </StackPanel>
                        <Separator />
                        <StackPanel Spacing="12">
                            <CheckBox Content="啟用診斷記錄" />
                            <CheckBox Content="自動清除快取" IsChecked="True" />
                            <Button Content="清除所有快取資料"
                                    HorizontalAlignment="Left"
                                    Theme="{DynamicResource MaterialOutlinedButton}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 開發者設定 -->
                <Border Classes="Card" Padding="28" CornerRadius="16" BoxShadow="0 4 16 0 #1F000000"
                        IsVisible="{Binding IsDeveloperMode}">
                    <StackPanel Spacing="24">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <avalonia:MaterialIcon Kind="CodeTags"
                                                   Width="32" Height="32"
                                                   Foreground="{DynamicResource ErrorBrush}" />
                            <StackPanel Spacing="4">
                                <TextBlock Text="開發者設定" Classes="Headline6"
                                           Foreground="{DynamicResource ErrorBrush}" />
                                <TextBlock Text="僅供開發與除錯使用，請勿在正式環境開啟"
                                           Classes="Body2" Opacity="0.7" />
                            </StackPanel>
                        </StackPanel>
                        <Separator />
                        <StackPanel Spacing="20">
                            <CheckBox Content="啟用詳細日誌記錄 (Verbose Logging)"
                                      IsChecked="{Binding EnableVerboseLogging}" />
                            <CheckBox Content="啟用效能監測"
                                      IsChecked="{Binding EnablePerformanceMonitoring}" />
                            <CheckBox Content="顯示內部除錯資訊"
                                      IsChecked="{Binding ShowDebugInfo}" />
                            <CheckBox Content="繞過生產環境檢查"
                                      IsChecked="{Binding BypassProductionChecks}" />

                            <!-- 開發者路徑設定 -->
                            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto" Margin="0,8,0,0">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Onnx模型根路徑"
                                           VerticalAlignment="Center" Classes="Body1" />
                                <TextBox Grid.Row="0" Grid.Column="1" Margin="24,0,0,0"
                                         Text="{Binding keyAutoMapper.ModelBaseUrl}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Github路徑"
                                           Margin="0,16,0,0" VerticalAlignment="Center" Classes="Body1" />
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="24,16,0,0"
                                         Text="{Binding GithubUrl}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="國內服務器根路徑"
                                           Margin="0,16,0,0" VerticalAlignment="Center" Classes="Body1" />
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="24,16,0,0"
                                         Text="{Binding CNServiceUrl}" />
                            </Grid>

                            <TextBlock Text="⚠️ 這些設定僅影響開發環境，正式版會自動忽略。"
                                       FontSize="13" Opacity="0.65" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 防止最後內容被底部按鈕遮擋的緩衝空間 -->
                <Border Height="60" />

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>